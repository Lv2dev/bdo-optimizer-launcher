{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BDO Optimizer",
  "version": "0.1.4",
  "identifier": "com.lv2dev.bdo-optimizer-launcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1421",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "dist"
  },
  "app": {
    "windows": [
      {
        "title": "BDO Optimizer",
        "width": 760,
        "height": 880,
        "minWidth": 720,
        "minHeight": 760,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; font-src 'self'; script-src 'self'; connect-src 'self'"
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "assets/app.ico"
    ]
  }
}
