import { CalendarDayUi, Theme } from "theme.slint";

export component CalendarPicker {
    in property <[CalendarDayUi]> days;
    in property <string> month-label;
    in property <int> selected-day: 0;
    in property <int> today-day: 0;
    callback prev-month();
    callback next-month();
    callback day-selected(int);

    private property <length> cw: (root.width - 20px) / 7;
    private property <length> ch: 28px;
    height: 32px + 22px + 6 * 28px + 10px;

    VerticalLayout {
        padding: 5px;
        spacing: 0;

        HorizontalLayout {
            height: 32px;
            spacing: 4px;
            Rectangle {
                width: 32px;
                border-radius: 4px;
                background: prev-ta.has-hover ? Theme.btn-h : Theme.btn;
                border-color: prev-ta.has-hover ? Theme.tgl-on : Theme.btn-bd;
                border-width: 1px;
                animate background { duration: 120ms; easing: ease-out; }
                animate border-color { duration: 120ms; easing: ease-out; }
                accessible-role: button;
                accessible-label: "이전 달";
                accessible-action-default => { root.prev-month(); }
                Text { text: "◀"; color: Theme.text-lo; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
                Rectangle {
                    x: 0; y: 0; width: parent.width; height: parent.height;
                    border-radius: parent.border-radius;
                    border-width: 2px;
                    border-color: Theme.tgl-on;
                    background: transparent;
                    opacity: prev-fs.has-focus ? 0.9 : 0.0;
                    animate opacity { duration: 150ms; easing: ease-out; }
                }
                prev-fs := FocusScope {
                    width: 100%; height: 100%;
                    key-pressed(event) => {
                        if (event.text == Key.Return || event.text == Key.Space) {
                            root.prev-month();
                            return accept;
                        }
                        return reject;
                    }
                }
                prev-ta := TouchArea { clicked => { prev-fs.focus(); root.prev-month(); } }
            }
            Text {
                text: root.month-label;
                color: Theme.text-accent;
                font-size: 13px;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }
            Rectangle {
                width: 32px;
                border-radius: 4px;
                background: next-ta.has-hover ? Theme.btn-h : Theme.btn;
                border-color: next-ta.has-hover ? Theme.tgl-on : Theme.btn-bd;
                border-width: 1px;
                animate background { duration: 120ms; easing: ease-out; }
                animate border-color { duration: 120ms; easing: ease-out; }
                accessible-role: button;
                accessible-label: "다음 달";
                accessible-action-default => { root.next-month(); }
                Text { text: "▶"; color: Theme.text-lo; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
                Rectangle {
                    x: 0; y: 0; width: parent.width; height: parent.height;
                    border-radius: parent.border-radius;
                    border-width: 2px;
                    border-color: Theme.tgl-on;
                    background: transparent;
                    opacity: next-fs.has-focus ? 0.9 : 0.0;
                    animate opacity { duration: 150ms; easing: ease-out; }
                }
                next-fs := FocusScope {
                    width: 100%; height: 100%;
                    key-pressed(event) => {
                        if (event.text == Key.Return || event.text == Key.Space) {
                            root.next-month();
                            return accept;
                        }
                        return reject;
                    }
                }
                next-ta := TouchArea { clicked => { next-fs.focus(); root.next-month(); } }
            }
        }

        HorizontalLayout {
            height: 22px;
            for dow[i] in ["일", "월", "화", "수", "목", "금", "토"]: Text {
                text: dow;
                color: Theme.text-lo;
                font-size: 10px;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }
        }

        Rectangle {
            height: 6 * root.ch;
            for cell[i] in root.days: Rectangle {
                x: Math.mod(i, 7) * root.cw;
                y: (i / 7) * root.ch;
                width: root.cw;
                height: root.ch;
                accessible-role: button;
                accessible-label: cell.day == 0 ? "" : cell.label + "일";
                accessible-action-default => { if (cell.day != 0) { root.day-selected(cell.day); } }

                Rectangle {
                    x: (root.cw - 24px) / 2;
                    y: 2px;
                    width: 24px;
                    height: 24px;
                    border-radius: 12px;
                    background: #ffffff;
                    opacity: (cell.day != 0 && cell.day != root.selected-day && cell-ta.has-hover) ? 0.06 : 0.0;
                    animate opacity { duration: 120ms; easing: ease-out; }
                }

                Rectangle {
                    x: (root.cw - 24px) / 2;
                    y: 2px;
                    width: 24px;
                    height: 24px;
                    border-radius: 12px;
                    background: (cell.day != 0 && cell.day == root.selected-day) ? #4a90e8 : transparent;
                    border-color: (cell.day != 0 && cell.day == root.today-day && cell.day != root.selected-day) ? #4a90e8 : transparent;
                    border-width: (cell.day != 0 && cell.day == root.today-day && cell.day != root.selected-day) ? 1.5px : 0;
                }

                Text {
                    x: 0; y: 0;
                    width: root.cw;
                    height: root.ch;
                    text: cell.label;
                    color: cell.day == 0 ? transparent
                         : cell.day == root.selected-day ? #ffffff
                         : cell.day == root.today-day ? #4a90e8
                         : Theme.text-lo;
                    font-size: 11px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                // 키보드 포커스 가시: 셀의 24x24 원형 영역에 맞춘 outline.
                Rectangle {
                    x: (root.cw - 24px) / 2;
                    y: 2px;
                    width: 24px;
                    height: 24px;
                    border-radius: 12px;
                    border-width: 2px;
                    border-color: Theme.tgl-on;
                    background: transparent;
                    opacity: (cell.day != 0 && cell-fs.has-focus) ? 0.9 : 0.0;
                    animate opacity { duration: 150ms; easing: ease-out; }
                }
                cell-fs := FocusScope {
                    width: 100%; height: 100%;
                    enabled: cell.day != 0;
                    key-pressed(event) => {
                        if (cell.day != 0 && (event.text == Key.Return || event.text == Key.Space)) {
                            root.day-selected(cell.day);
                            return accept;
                        }
                        return reject;
                    }
                }

                cell-ta := TouchArea {
                    enabled: cell.day != 0;
                    clicked => { if (cell.day != 0) { cell-fs.focus(); root.day-selected(cell.day); } }
                }
            }
        }
    }
}

export component TimePicker {
    in property <string> hour-text: "00";
    in property <string> minute-text: "00";
    callback hour-up();
    callback hour-down();
    callback minute-up();
    callback minute-down();
    callback hour-edited(string);
    callback minute-edited(string);

    min-height: 90px;
    preferred-height: 90px;
    max-height: 90px;
    vertical-stretch: 0;

    HorizontalLayout {
        width: 100%;
        height: 90px;
        alignment: center;
        spacing: 8px;

        VerticalLayout {
            alignment: center;
            spacing: 3px;
            Text { text: "시"; color: Theme.text-lo; font-size: 9px; horizontal-alignment: center; }
            Rectangle {
                width: 44px; height: 22px;
                border-radius: 4px;
                background: hu-ta.has-hover ? Theme.btn-h : Theme.btn;
                border-color: hu-ta.has-hover ? Theme.tgl-on : Theme.btn-bd;
                border-width: 1px;
                animate background { duration: 120ms; easing: ease-out; }
                animate border-color { duration: 120ms; easing: ease-out; }
                accessible-role: button;
                accessible-label: "시 증가";
                accessible-action-default => { root.hour-up(); }
                Text { text: "▲"; color: Theme.text-lo; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
                Rectangle {
                    x: 0; y: 0; width: parent.width; height: parent.height;
                    border-radius: parent.border-radius;
                    border-width: 2px;
                    border-color: Theme.tgl-on;
                    background: transparent;
                    opacity: hu-fs.has-focus ? 0.9 : 0.0;
                    animate opacity { duration: 150ms; easing: ease-out; }
                }
                hu-fs := FocusScope {
                    width: 100%; height: 100%;
                    key-pressed(event) => {
                        if (event.text == Key.Return || event.text == Key.Space) {
                            root.hour-up();
                            return accept;
                        }
                        return reject;
                    }
                }
                hu-ta := TouchArea { clicked => { hu-fs.focus(); root.hour-up(); } }
            }
            Rectangle {
                width: 44px;
                height: 36px;
                border-radius: 4px;
                background: Theme.log-bg;
                border-color: hour-input.has-focus ? #4a90e8 : Theme.log-bd;
                border-width: 1px;
                animate border-color { duration: 150ms; easing: ease; }
                hour-input := TextInput {
                    text: root.hour-text;
                    color: Theme.text-accent;
                    font-size: 24px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    width: 100%;
                    height: 100%;
                    input-type: number;
                    single-line: true;
                    accepted => { root.hour-edited(self.text); }
                    changed has-focus => {
                        if (!self.has-focus) {
                            root.hour-edited(self.text);
                        }
                    }
                }
            }
            Rectangle {
                width: 44px; height: 22px;
                border-radius: 4px;
                background: hd-ta.has-hover ? Theme.btn-h : Theme.btn;
                border-color: hd-ta.has-hover ? Theme.tgl-on : Theme.btn-bd;
                border-width: 1px;
                animate background { duration: 120ms; easing: ease-out; }
                animate border-color { duration: 120ms; easing: ease-out; }
                accessible-role: button;
                accessible-label: "시 감소";
                accessible-action-default => { root.hour-down(); }
                Text { text: "▼"; color: Theme.text-lo; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
                Rectangle {
                    x: 0; y: 0; width: parent.width; height: parent.height;
                    border-radius: parent.border-radius;
                    border-width: 2px;
                    border-color: Theme.tgl-on;
                    background: transparent;
                    opacity: hd-fs.has-focus ? 0.9 : 0.0;
                    animate opacity { duration: 150ms; easing: ease-out; }
                }
                hd-fs := FocusScope {
                    width: 100%; height: 100%;
                    key-pressed(event) => {
                        if (event.text == Key.Return || event.text == Key.Space) {
                            root.hour-down();
                            return accept;
                        }
                        return reject;
                    }
                }
                hd-ta := TouchArea { clicked => { hd-fs.focus(); root.hour-down(); } }
            }
        }

        Text {
            text: ":";
            color: Theme.text-lo;
            font-size: 28px;
            font-weight: 700;
            vertical-alignment: center;
        }

        VerticalLayout {
            alignment: center;
            spacing: 3px;
            Text { text: "분"; color: Theme.text-lo; font-size: 9px; horizontal-alignment: center; }
            Rectangle {
                width: 44px; height: 22px;
                border-radius: 4px;
                background: mu-ta.has-hover ? Theme.btn-h : Theme.btn;
                border-color: mu-ta.has-hover ? Theme.tgl-on : Theme.btn-bd;
                border-width: 1px;
                animate background { duration: 120ms; easing: ease-out; }
                animate border-color { duration: 120ms; easing: ease-out; }
                accessible-role: button;
                accessible-label: "분 증가";
                accessible-action-default => { root.minute-up(); }
                Text { text: "▲"; color: Theme.text-lo; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
                Rectangle {
                    x: 0; y: 0; width: parent.width; height: parent.height;
                    border-radius: parent.border-radius;
                    border-width: 2px;
                    border-color: Theme.tgl-on;
                    background: transparent;
                    opacity: mu-fs.has-focus ? 0.9 : 0.0;
                    animate opacity { duration: 150ms; easing: ease-out; }
                }
                mu-fs := FocusScope {
                    width: 100%; height: 100%;
                    key-pressed(event) => {
                        if (event.text == Key.Return || event.text == Key.Space) {
                            root.minute-up();
                            return accept;
                        }
                        return reject;
                    }
                }
                mu-ta := TouchArea { clicked => { mu-fs.focus(); root.minute-up(); } }
            }
            Rectangle {
                width: 44px;
                height: 36px;
                border-radius: 4px;
                background: Theme.log-bg;
                border-color: minute-input.has-focus ? #4a90e8 : Theme.log-bd;
                border-width: 1px;
                animate border-color { duration: 150ms; easing: ease; }
                minute-input := TextInput {
                    text: root.minute-text;
                    color: Theme.text-accent;
                    font-size: 24px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    width: 100%;
                    height: 100%;
                    input-type: number;
                    single-line: true;
                    accepted => { root.minute-edited(self.text); }
                    changed has-focus => {
                        if (!self.has-focus) {
                            root.minute-edited(self.text);
                        }
                    }
                }
            }
            Rectangle {
                width: 44px; height: 22px;
                border-radius: 4px;
                background: md-ta.has-hover ? Theme.btn-h : Theme.btn;
                border-color: md-ta.has-hover ? Theme.tgl-on : Theme.btn-bd;
                border-width: 1px;
                animate background { duration: 120ms; easing: ease-out; }
                animate border-color { duration: 120ms; easing: ease-out; }
                accessible-role: button;
                accessible-label: "분 감소";
                accessible-action-default => { root.minute-down(); }
                Text { text: "▼"; color: Theme.text-lo; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
                Rectangle {
                    x: 0; y: 0; width: parent.width; height: parent.height;
                    border-radius: parent.border-radius;
                    border-width: 2px;
                    border-color: Theme.tgl-on;
                    background: transparent;
                    opacity: md-fs.has-focus ? 0.9 : 0.0;
                    animate opacity { duration: 150ms; easing: ease-out; }
                }
                md-fs := FocusScope {
                    width: 100%; height: 100%;
                    key-pressed(event) => {
                        if (event.text == Key.Return || event.text == Key.Space) {
                            root.minute-down();
                            return accept;
                        }
                        return reject;
                    }
                }
                md-ta := TouchArea { clicked => { md-fs.focus(); root.minute-down(); } }
            }
        }
    }
}
