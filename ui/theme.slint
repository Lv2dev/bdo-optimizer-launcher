export enum ThemeMode { light, dark, system }
export enum RuleKind { daily, weekday, weekend, specific }
export enum OptimizeMode { high, normal, low_power }

export struct ScheduleRuleUi {
    id: int,
    summary: string,
    active: bool,
}

export struct CalendarDayUi {
    day: int,
    label: string,
}

export global Theme {
    in-out property <bool> dark: true;
    in-out property <float> motion-scale: 1.0;

    out property <color> bg:            dark ? #0d1117 : #f5f7f8;
    out property <color> panel:         dark ? #151a21 : #ffffff;
    out property <color> panel-bd:      dark ? #2a323d : #cfd8dc;
    out property <color> text-hi:       dark ? #eef3f5 : #162126;
    out property <color> text-lo:       dark ? #8b969e : #607078;
    out property <color> text-accent:   dark ? #7dd3c7 : #00796b;
    out property <color> text-section:  dark ? #5ec2b5 : #00695c;
    out property <color> text-desc:     dark ? #849099 : #65737b;
    out property <color> text-status:   dark ? #8bcfc6 : #00796b;
    out property <color> log-bg:        dark ? #11161c : #eef3f4;
    out property <color> log-bd:        dark ? #29323a : #c8d3d6;
    out property <color> btn:           dark ? #202830 : #e3eaec;
    out property <color> btn-h:         dark ? #26313a : #d5e0e3;
    out property <color> btn-bd:        dark ? #37424d : #b8c6ca;
    out property <color> row:           dark ? #11171d : #f8fafb;
    out property <color> row-act-bd:    dark ? #267c72 : #00897b;
    out property <color> row-inact-bd:  dark ? #29323a : #d7e0e3;
    out property <color> row-act-tx:    dark ? #d8efec : #162126;
    out property <color> row-inact-tx:  dark ? #6f7a82 : #607078;
    out property <color> tgl-bg:        dark ? #172229 : #e4ecee;
    out property <color> tgl-bg-h:      dark ? #1d3036 : #d7e3e5;
    out property <color> tgl-on:        dark ? #14b8a6 : #00897b;
    out property <color> tgl-off:       dark ? #52616b : #6f7f86;
    out property <color> del-bg:        dark ? #281010 : #f8ecec;
    out property <color> del-bg-h:      dark ? #3d1515 : #f0d8d8;
    out property <color> del-text:      dark ? #bb4444 : #cc2222;
    out property <color> btn-game:      dark ? #006c64 : #00695c;
    out property <color> btn-game-h:    dark ? #00897b : #00574f;
    out property <color> btn-high:      dark ? #163a20 : #1a7030;
    out property <color> btn-high-h:    dark ? #1e5030 : #1e8838;
    out property <color> btn-cancel:    dark ? #3a1212 : #bb2222;
    out property <color> btn-cancel-h:  dark ? #501616 : #dd2222;
    out property <color> btn-sched:     dark ? #17424a : #00796b;
    out property <color> btn-sched-h:   dark ? #20535b : #00695c;
    out property <color> btn-sd-act:    dark ? #334047 : #607d8b;
    out property <color> btn-sd-act-h:  dark ? #3f4d55 : #546e7a;
    out property <color> text-btn-game:    dark ? #eef2ff : #ffffff;
    out property <color> text-btn-high:    dark ? #d0f0d8 : #1a6030;
    out property <color> text-btn-cancel:  dark ? #ffe0e0 : #aa1a1a;
    out property <color> text-btn-sd:      dark ? #eaf2f4 : #23343a;
    out property <color> text-btn-sched:   dark ? #ddeeff : #ffffff;

    out property <color> tab-bar-bg:       dark ? #121820 : #e9eef0;
    out property <color> tab-active-line:  dark ? #14b8a6 : #00897b;
    out property <color> tab-active-tx:    dark ? #eef3f5 : #162126;
    out property <color> tab-inactive-tx:  dark ? #7d8890 : #4b5960;
    out property <color> acc-sd-bg:        dark ? #261000 : #fff8f0;
    out property <color> acc-sd-bd:        dark ? #8a3a15 : #e0a070;
    out property <color> acc-sd-title:     dark ? #ff9d35 : #b85000;
    out property <color> acc-sd-pill-bg:   dark ? #7b3a2a : #f0c090;
    out property <color> acc-sd-pill-tx:   dark ? #ffd0a0 : #7a3000;
    out property <color> acc-auto-bd-open: dark ? #35615c : #80cbc4;
    out property <color> btn-low-power:         dark ? #1a2a35 : #2a5060;
    out property <color> btn-low-power-h:       dark ? #243a4a : #356070;
    out property <color> text-btn-low-power:    dark ? #c0e0f0 : #1a4060;
    out property <color> btn-sd-reg:       dark ? #ee8500 : #9a4200;
    out property <color> btn-sd-reg-h:     dark ? #ff9a18 : #803600;
    out property <color> text-btn-sd-reg:  #fff8f0;
    out property <color> badge-high:       #27ae60;
    out property <color> badge-low-power:       #4f7f8c;

    // === 그라디언트 stop 색상 (M18 비주얼 리디자인) ===
    // 타이틀 바
    out property <color> title-grad-1:     dark ? #151a21 : #ffffff;
    out property <color> title-grad-2:     dark ? #182128 : #f6f9fa;
    // 카드 배경
    out property <color> card-grad-1:      dark ? #151a21 : #ffffff;
    out property <color> card-grad-2:      dark ? #182028 : #f8fafb;
    // 하단 상태바
    out property <color> bar-grad-1:       dark ? #0f141a : #eef3f4;
    out property <color> bar-grad-2:       dark ? #121920 : #e6eef0;
    // 탭 인디케이터 라인
    out property <color> tab-line-1:       dark ? #14b8a6 : #00897b;
    out property <color> tab-line-2:       dark ? #5eead4 : #26a69a;
    // 버튼 그라디언트 — Primary (게임 실행)
    out property <color> btn-primary-1:    dark ? #006c64 : #00695c;
    out property <color> btn-primary-2:    dark ? #00897b : #00574f;
    // 버튼 그라디언트 — Secondary (일반)
    out property <color> btn-sec-1:        dark ? #202830 : #edf2f3;
    out property <color> btn-sec-2:        dark ? #26313a : #e4ecee;
    // 버튼 그라디언트 — Success (고성능)
    out property <color> btn-suc-1:        dark ? #163a20 : #d0f0d8;
    out property <color> btn-suc-2:        dark ? #1e5030 : #c0e8cc;
    // 버튼 그라디언트 — LowPower (저전력)
    out property <color> btn-lp-1:         dark ? #1a2a35 : #d0e8f0;
    out property <color> btn-lp-2:         dark ? #22384a : #c0d8e8;
    // 버튼 그라디언트 — Warning (예약 등록)
    out property <color> btn-warn-1:       dark ? #7a3500 : #9a4200;
    out property <color> btn-warn-2:       dark ? #993f00 : #803600;
    // 버튼 그라디언트 — Danger (예약 취소)
    out property <color> btn-dan-1:        dark ? #3a0e0e : #f4e8e8;
    out property <color> btn-dan-2:        dark ? #501414 : #edd8d8;
    // pill border
    out property <color> pill-ok-bd:       dark ? #1e5030 : #a0d8b0;
    out property <color> pill-none-bd:     dark ? #2a323d : #d3dee1;
    out property <color> pill-act-bd:      dark ? #344049 : #cfd8dc;
}
