import { LineEdit, ScrollView } from "std-widgets.slint";
import { Theme, ThemeMode } from "../theme.slint";
import { CheckIcon, SectionHeader, HelpTooltip } from "../widgets.slint";
import { DBtn, ToggleSwitch } from "../buttons.slint";

export component SettingsTab inherits ScrollView {
    in property <ThemeMode> theme-mode;
    in property <bool> reduce-motion;
    in property <bool> auto-tray-on-game-minimize;
    in property <bool> close-to-tray;
    in property <bool> autostart-enabled;
    in property <bool> autostart-minimized;
    in property <string> app-version;
    in property <string> update-status-text;
    in property <bool> update-available;
    in property <bool> update-checking;
    in property <string> update-release-url;
    in-out property <string> launcher-path;
    callback change-theme(ThemeMode);
    callback toggle-reduce-motion(bool);
    callback toggle-auto-tray(bool);
    callback toggle-close-to-tray(bool);
    callback toggle-autostart(bool);
    callback toggle-autostart-minimized(bool);
    callback open-log-folder();
    callback launcher-path-changed(string);
    callback check-for-updates();
    callback open-update-release();

    vertical-stretch: 1;
    property <float> tab-fade: 0.0;
    property <length> tab-slide: 18px;
    opacity: tab-fade;
    x: tab-slide;
    // M89-3: 탭 진입 더 명확 — fade 240→400ms, slide 320→480ms.
    animate tab-fade { duration: 400ms * Theme.motion-scale; easing: cubic-bezier(0.16, 1, 0.3, 1); }
    animate tab-slide { duration: 480ms * Theme.motion-scale; easing: cubic-bezier(0.16, 1, 0.3, 1); }
    init => { tab-fade = 1.0; tab-slide = 0px; }

    VerticalLayout {
        padding: 16px;
        spacing: 10px;
        width: parent.width;
        alignment: start;

        Rectangle {
            background: @linear-gradient(135deg, Theme.card-grad-1 0%, Theme.card-grad-2 100%);
            border-radius: 8px;
            border-width: 1px;
            border-color: Theme.panel-bd;
            animate background { duration: 220ms * Theme.motion-scale; delay: 0ms; easing: ease; }
            animate border-color { duration: 220ms * Theme.motion-scale; delay: 0ms; easing: ease; }

            VerticalLayout {
                padding: 14px;
                spacing: 4px;

                SectionHeader {
                    label: "테마";
                    desc: "앱 표시 색상을 변경합니다.";
                }

                Rectangle {
                    height: 44px;
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: root.theme-mode == ThemeMode.light ? Theme.tgl-on : Theme.panel-bd;
                    background: root.theme-mode == ThemeMode.light ? Theme.tgl-bg : Theme.panel;
                    animate background { duration: 150ms; easing: ease-out; }
                    animate border-color { duration: 150ms; easing: ease-out; }
                    HorizontalLayout {
                        padding: 8px;
                        spacing: 10px;
                        alignment: center;
                        Text { text: "☀️"; font-size: 18px; vertical-alignment: center; }
                        Text {
                            text: "라이트 모드";
                            font-size: 13px;
                            color: Theme.text-hi;
                            horizontal-stretch: 1;
                            vertical-alignment: center;
                        }
                        if root.theme-mode == ThemeMode.light : CheckIcon {
                            icon-color: Theme.tgl-on;
                        }
                    }
                    Rectangle {
                        background: Theme.tgl-on;
                        opacity: th-light-ta.has-hover && root.theme-mode != ThemeMode.light ? 0.06 : 0.0;
                        animate opacity { duration: 150ms; easing: ease-out; }
                    }
                    th-light-ta := TouchArea {
                        width: 100%;
                        height: 100%;
                        clicked => { root.change-theme(ThemeMode.light); }
                    }
                }

                Rectangle {
                    height: 44px;
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: root.theme-mode == ThemeMode.dark ? Theme.tgl-on : Theme.panel-bd;
                    background: root.theme-mode == ThemeMode.dark ? Theme.tgl-bg : Theme.panel;
                    animate background { duration: 150ms; easing: ease-out; }
                    animate border-color { duration: 150ms; easing: ease-out; }
                    HorizontalLayout {
                        padding: 8px;
                        spacing: 10px;
                        alignment: center;
                        Text { text: "🌙"; font-size: 18px; vertical-alignment: center; }
                        Text {
                            text: "다크 모드";
                            font-size: 13px;
                            color: Theme.text-hi;
                            horizontal-stretch: 1;
                            vertical-alignment: center;
                        }
                        if root.theme-mode == ThemeMode.dark : CheckIcon {
                            icon-color: Theme.tgl-on;
                        }
                    }
                    Rectangle {
                        background: Theme.tgl-on;
                        opacity: th-dark-ta.has-hover && root.theme-mode != ThemeMode.dark ? 0.06 : 0.0;
                        animate opacity { duration: 150ms; easing: ease-out; }
                    }
                    th-dark-ta := TouchArea {
                        width: 100%;
                        height: 100%;
                        clicked => { root.change-theme(ThemeMode.dark); }
                    }
                }

                Rectangle {
                    height: 52px;
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: root.theme-mode == ThemeMode.system ? Theme.tgl-on : Theme.panel-bd;
                    background: root.theme-mode == ThemeMode.system ? Theme.tgl-bg : Theme.panel;
                    animate background { duration: 150ms; easing: ease-out; }
                    animate border-color { duration: 150ms; easing: ease-out; }
                    HorizontalLayout {
                        padding: 8px;
                        spacing: 10px;
                        alignment: center;
                        Text { text: "🔄"; font-size: 18px; vertical-alignment: center; }
                        VerticalLayout {
                            alignment: center;
                            horizontal-stretch: 1;
                            Text {
                                text: "자동 (OS 설정)";
                                font-size: 13px;
                                color: Theme.text-hi;
                            }
                            Text {
                                text: "Windows 앱 테마 설정을 따릅니다.";
                                font-size: 11px;
                                color: Theme.text-desc;
                            }
                        }
                        if root.theme-mode == ThemeMode.system : CheckIcon {
                            icon-color: Theme.tgl-on;
                        }
                    }
                    Rectangle {
                        background: Theme.tgl-on;
                        opacity: th-sys-ta.has-hover && root.theme-mode != ThemeMode.system ? 0.06 : 0.0;
                        animate opacity { duration: 150ms; easing: ease-out; }
                    }
                    th-sys-ta := TouchArea {
                        width: 100%;
                        height: 100%;
                        clicked => { root.change-theme(ThemeMode.system); }
                    }
                }
            }
            z: 7;
            st1_tip := HelpTooltip {
                x: parent.width - 26px;
                y: 10px;
                text: "앱 색상 테마(라이트/다크/자동)를 선택합니다.";
            }
        }

        Rectangle {
            background: @linear-gradient(135deg, Theme.card-grad-1 0%, Theme.card-grad-2 100%);
            border-radius: 8px;
            border-width: 1px;
            border-color: Theme.panel-bd;
            animate background { duration: 220ms * Theme.motion-scale; delay: 60ms * Theme.motion-scale; easing: ease; }
            animate border-color { duration: 220ms * Theme.motion-scale; delay: 60ms * Theme.motion-scale; easing: ease; }

            VerticalLayout {
                padding: 14px;
                spacing: 10px;
                Text {
                    text: "접근성";
                    font-size: 14px;
                    color: Theme.text-status;
                }
                Text {
                    text: "애니메이션 줄이기를 켜면 신규 모션이 비활성됩니다. 배터리 절약과 시각적 피로 감소에 도움이 됩니다.";
                    font-size: 11px;
                    color: Theme.text-desc;
                    wrap: word-wrap;
                }
                HorizontalLayout {
                    spacing: 12px;
                    alignment: start;
                    ToggleSwitch {
                        checked: root.reduce-motion;
                        accessible-label-text: "애니메이션 줄이기";
                        toggled => { root.toggle-reduce-motion(!root.reduce-motion); }
                    }
                    Text {
                        text: root.reduce-motion ? "켜짐" : "꺼짐";
                        font-size: 12px;
                        color: Theme.text-status;
                        vertical-alignment: center;
                    }
                }
            }
            z: 6;
            st2_tip := HelpTooltip {
                x: parent.width - 26px;
                y: 10px;
                text: "애니메이션 강도를 조절합니다.";
            }
        }

        Rectangle {
            background: @linear-gradient(135deg, Theme.card-grad-1 0%, Theme.card-grad-2 100%);
            border-radius: 8px;
            border-width: 1px;
            border-color: Theme.panel-bd;
            animate background { duration: 220ms * Theme.motion-scale; delay: 90ms * Theme.motion-scale; easing: ease; }
            animate border-color { duration: 220ms * Theme.motion-scale; delay: 90ms * Theme.motion-scale; easing: ease; }

            VerticalLayout {
                padding: 14px;
                spacing: 10px;
                Text {
                    text: "런처 동작";
                    font-size: 14px;
                    color: Theme.text-status;
                }

                // 자동 트레이 모드
                HorizontalLayout {
                    spacing: 12px;
                    alignment: start;
                    ToggleSwitch {
                        checked: root.auto-tray-on-game-minimize;
                        accessible-label-text: "게임 트레이 진입 시 자동 저전력";
                        toggled => { root.toggle-auto-tray(!root.auto-tray-on-game-minimize); }
                    }
                    VerticalLayout {
                        alignment: center;
                        horizontal-stretch: 1;
                        Text {
                            text: "게임이 트레이로 내려가면 자동 저전력 모드";
                            font-size: 12px;
                            color: Theme.text-status;
                        }
                        Text {
                            text: "검은사막 창이 숨겨지면 저전력 모드 적용, 다시 나타나면 직전 모드로 복원합니다.";
                            font-size: 11px;
                            color: Theme.text-desc;
                            wrap: word-wrap;
                        }
                    }
                }

                Rectangle { height: 1px; background: Theme.panel-bd; }

                // 닫기 시 트레이로 숨기기
                HorizontalLayout {
                    spacing: 12px;
                    alignment: start;
                    ToggleSwitch {
                        checked: root.close-to-tray;
                        accessible-label-text: "창 닫기 시 트레이로 숨기기";
                        toggled => { root.toggle-close-to-tray(!root.close-to-tray); }
                    }
                    VerticalLayout {
                        alignment: center;
                        horizontal-stretch: 1;
                        Text {
                            text: "창 닫기 시 트레이로 숨기기";
                            font-size: 12px;
                            color: Theme.text-status;
                        }
                        Text {
                            text: "끄면 X 버튼 클릭 시 앱이 완전히 종료됩니다.";
                            font-size: 11px;
                            color: Theme.text-desc;
                            wrap: word-wrap;
                        }
                    }
                }
            }
            z: 5;
            st3_tip := HelpTooltip {
                x: parent.width - 26px;
                y: 10px;
                text: "검은사막이 트레이로 내려갈 때와 X 버튼을 누를 때의 동작을 설정합니다.";
            }
        }

        Rectangle {
            background: @linear-gradient(135deg, Theme.card-grad-1 0%, Theme.card-grad-2 100%);
            border-radius: 8px;
            border-width: 1px;
            border-color: Theme.panel-bd;
            animate background { duration: 220ms * Theme.motion-scale; delay: 120ms * Theme.motion-scale; easing: ease; }
            animate border-color { duration: 220ms * Theme.motion-scale; delay: 120ms * Theme.motion-scale; easing: ease; }

            VerticalLayout {
                padding: 14px;
                spacing: 10px;
                Text {
                    text: "시작 옵션";
                    font-size: 14px;
                    color: Theme.text-status;
                }
                Text {
                    text: "Windows 로그온 시 자동으로 실행합니다. 작업 스케줄러에 등록되어 UAC 프롬프트 없이 승격 실행됩니다.";
                    font-size: 11px;
                    color: Theme.text-desc;
                    wrap: word-wrap;
                }

                // 자동 시작 토글
                HorizontalLayout {
                    spacing: 12px;
                    alignment: start;
                    ToggleSwitch {
                        checked: root.autostart-enabled;
                        accessible-label-text: "Windows 시작 시 자동 실행";
                        toggled => { root.toggle-autostart(!root.autostart-enabled); }
                    }
                    Text {
                        text: "Windows 시작 시 자동 실행";
                        font-size: 12px;
                        color: Theme.text-status;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }
                }

                Rectangle { height: 1px; background: Theme.panel-bd; }

                // 트레이 시작 토글 (자동 시작이 꺼져 있으면 비활성)
                HorizontalLayout {
                    spacing: 12px;
                    alignment: start;
                    ToggleSwitch {
                        checked: root.autostart-minimized;
                        enabled: root.autostart-enabled;
                        accessible-label-text: "자동 실행 시 트레이로 시작";
                        toggled => { root.toggle-autostart-minimized(!root.autostart-minimized); }
                    }
                    VerticalLayout {
                        alignment: center;
                        horizontal-stretch: 1;
                        Text {
                            text: "자동 실행 시 트레이로 시작";
                            font-size: 12px;
                            color: root.autostart-enabled ? Theme.text-status : Theme.text-desc;
                            animate color { duration: 150ms; easing: ease-out; }
                        }
                        Text {
                            text: "켜면 부팅 시 창을 띄우지 않고 트레이에만 상주합니다.";
                            font-size: 11px;
                            color: Theme.text-desc;
                            wrap: word-wrap;
                        }
                    }
                }
            }
            z: 4;
            st4_tip := HelpTooltip {
                x: parent.width - 26px;
                y: 10px;
                text: "Windows 로그온 시 앱 자동 실행 여부를 설정합니다.";
            }
        }

        Rectangle {
            background: @linear-gradient(135deg, Theme.card-grad-1 0%, Theme.card-grad-2 100%);
            border-radius: 8px;
            border-width: 1px;
            border-color: Theme.panel-bd;
            animate background { duration: 220ms * Theme.motion-scale; delay: 150ms * Theme.motion-scale; easing: ease; }
            animate border-color { duration: 220ms * Theme.motion-scale; delay: 150ms * Theme.motion-scale; easing: ease; }

            VerticalLayout {
                padding: 14px;
                spacing: 8px;

                SectionHeader {
                    label: "런처 경로";
                    desc: "저장된 경로가 없으면 자동으로 탐색합니다.";
                }

                LineEdit {
                    text: root.launcher-path;
                    placeholder-text: "저장된 경로 없음 (자동 탐색)";
                    edited(t) => {
                        root.launcher-path = t;
                        root.launcher-path-changed(t);
                    }
                }

                DBtn {
                    text: "경로 초기화";
                    grad-1: Theme.btn-sec-1;
                    grad-2: Theme.btn-sec-2;
                    grad-h-1: Theme.btn-sec-2;
                    grad-h-2: Theme.btn-sec-1;
                    clicked => {
                        root.launcher-path = "";
                        root.launcher-path-changed("");
                    }
                }
            }
            z: 3;
            st5_tip := HelpTooltip {
                x: parent.width - 26px;
                y: 10px;
                text: "검은사막 런처의 경로를 직접 지정합니다. 비어 있으면 자동 탐색.";
            }
        }

        Rectangle {
            background: @linear-gradient(135deg, Theme.card-grad-1 0%, Theme.card-grad-2 100%);
            border-radius: 8px;
            border-width: 1px;
            border-color: Theme.panel-bd;
            animate background { duration: 220ms * Theme.motion-scale; delay: 180ms * Theme.motion-scale; easing: ease; }
            animate border-color { duration: 220ms * Theme.motion-scale; delay: 180ms * Theme.motion-scale; easing: ease; }

            VerticalLayout {
                padding: 14px;
                spacing: 8px;

                SectionHeader {
                    label: "업데이트";
                    desc: "GitHub Release 기준으로 최신 버전을 확인합니다.";
                }

                Text {
                    text: root.update-status-text;
                    font-size: 11px;
                    color: root.update-available ? Theme.text-accent : Theme.text-desc;
                    wrap: word-wrap;
                    horizontal-stretch: 1;
                }

                HorizontalLayout {
                    spacing: 8px;

                    DBtn {
                        text: root.update-checking ? "확인 중..." : "업데이트 확인";
                        enabled: !root.update-checking;
                        grad-1: Theme.btn-sec-1;
                        grad-2: Theme.btn-sec-2;
                        grad-h-1: Theme.btn-sec-2;
                        grad-h-2: Theme.btn-sec-1;
                        horizontal-stretch: 1;
                        clicked => { root.check-for-updates(); }
                    }

                    if root.update-available && root.update-release-url != "" : DBtn {
                        text: "릴리스 열기";
                        grad-1: Theme.btn-primary-1;
                        grad-2: Theme.btn-primary-2;
                        grad-h-1: Theme.btn-primary-2;
                        grad-h-2: Theme.btn-primary-1;
                        horizontal-stretch: 1;
                        clicked => { root.open-update-release(); }
                    }
                }
            }
            z: 2;
            st6_tip := HelpTooltip {
                x: parent.width - 26px;
                y: 10px;
                text: "앱은 자동으로 실행 파일을 교체하지 않고, 새 릴리스가 있으면 GitHub 페이지를 엽니다.";
            }
        }

        // M64: 진단 카드 — 로그 폴더 열기 버튼. 버그 보고 시 로그 파일 첨부 편의.
        Rectangle {
            background: @linear-gradient(135deg, Theme.card-grad-1 0%, Theme.card-grad-2 100%);
            border-radius: 8px;
            border-width: 1px;
            border-color: Theme.panel-bd;
            animate background { duration: 220ms * Theme.motion-scale; delay: 210ms * Theme.motion-scale; easing: ease; }
            animate border-color { duration: 220ms * Theme.motion-scale; delay: 210ms * Theme.motion-scale; easing: ease; }

            VerticalLayout {
                padding: 14px;
                spacing: 8px;

                SectionHeader {
                    label: "진단";
                    desc: "버그 보고 시 로그 파일을 첨부하면 진단에 도움이 됩니다.";
                }

                DBtn {
                    text: "로그 폴더 열기";
                    grad-1: Theme.btn-sec-1;
                    grad-2: Theme.btn-sec-2;
                    grad-h-1: Theme.btn-sec-2;
                    grad-h-2: Theme.btn-sec-1;
                    clicked => { root.open-log-folder(); }
                }
            }
            z: 1;
            st7_tip := HelpTooltip {
                x: parent.width - 26px;
                y: 10px;
                text: "앱이 기록한 진단 로그(이벤트·오류·패닉)가 저장된 폴더를 엽니다.";
            }
        }

        Text {
            text: "bdo-optimizer-launcher v" + root.app-version;
            color: Theme.text-desc;
            font-size: 11px;
            horizontal-alignment: center;
        }
    }
}
