import { LineEdit, ScrollView, CheckBox, ComboBox } from "std-widgets.slint";
import { ScheduleRuleUi, CalendarDayUi, Theme, RuleKind, OptimizeMode } from "../theme.slint";
import { DBtn, TwoButtonRow, ToggleSwitch, WeekdayChip, ClickableSurface } from "../buttons.slint";
import { CalendarPicker, TimePicker } from "../pickers.slint";
import { HelpTooltip } from "../widgets.slint";

export component ScheduleTab inherits ScrollView {
    in-out property <bool> auto-mode-expanded;
    in property <bool> schedule-empty;
    in property <string> active-rule-info;
    in property <[ScheduleRuleUi]> schedule-rules;
    in-out property <string> new-rule-name;
    in-out property <RuleKind> new-rule-kind;
    in-out property <string> new-rule-date;
    in-out property <string> new-rule-start;
    in-out property <string> new-rule-end;
    in-out property <OptimizeMode> new-rule-mode;
    in property <float> shutdown-flash;
    in property <string> shutdown-once-text;
    in property <bool> shutdown-once-active;
    in property <string> shutdown-weekly-text;
    in property <bool> shutdown-weekly-active;
    in-out property <bool> shutdown-expanded;
    in-out property <bool> shutdown-weekly;
    in-out property <bool> cal-open;
    in property <string> cal-selected-label;
    in property <[CalendarDayUi]> cal-days;
    in property <string> cal-month-label;
    in property <int> cal-selected-day;
    in property <int> cal-today-day;
    in-out property <bool> shutdown-mon;
    in-out property <bool> shutdown-tue;
    in-out property <bool> shutdown-wed;
    in-out property <bool> shutdown-thu;
    in-out property <bool> shutdown-fri;
    in-out property <bool> shutdown-sat;
    in-out property <bool> shutdown-sun;
    in property <string> shutdown-hour-text;
    in property <string> shutdown-minute-text;
    callback add-schedule-rule();
    callback delete-schedule-rule(int);
    callback toggle-schedule-rule(int);
    callback cal-prev-month();
    callback cal-next-month();
    callback cal-select-day(int);
    callback shutdown-hour-up();
    callback shutdown-hour-down();
    callback shutdown-minute-up();
    callback shutdown-minute-down();
    callback shutdown-hour-set(string);
    callback shutdown-minute-set(string);
    callback register-shutdown();
    callback cancel-once-shutdown();
    callback cancel-weekly-shutdown();

    vertical-stretch: 1;
    property <float> tab-fade: 0.0;
    property <length> tab-slide: 18px;
    opacity: tab-fade;
    x: tab-slide;
    // M89-3: 탭 진입 더 명확 — fade 240→400ms, slide 320→480ms.
    animate tab-fade { duration: 400ms * Theme.motion-scale; easing: cubic-bezier(0.16, 1, 0.3, 1); }
    animate tab-slide { duration: 480ms * Theme.motion-scale; easing: cubic-bezier(0.16, 1, 0.3, 1); }
    init => { tab-fade = 1.0; tab-slide = 0px; }

    VerticalLayout {
        padding: 16px;
        spacing: 10px;
        width: parent.width;
        alignment: start;

        Rectangle {
            border-radius: 8px;
            border-width: 1px;
            border-color: root.auto-mode-expanded ? Theme.acc-auto-bd-open : Theme.panel-bd;
            background: @linear-gradient(135deg, Theme.card-grad-1 0%, Theme.card-grad-2 100%);
            animate background { duration: 220ms * Theme.motion-scale; easing: ease; }
            animate border-color { duration: 220ms * Theme.motion-scale; easing: ease; }

            VerticalLayout {
                Rectangle {
                    height: 58px;
                    background: transparent;

                    VerticalLayout {
                        padding-left: 12px;
                        padding-right: 12px;
                        padding-top: 8px;
                        padding-bottom: 7px;
                        spacing: 3px;

                        HorizontalLayout {
                            spacing: 8px;
                            alignment: center;

                            Text { text: "📅"; font-size: 14px; vertical-alignment: center; }
                            Text {
                                text: "자동 모드 전환";
                                color: Theme.text-hi;
                                font-size: 13px;
                                font-weight: 700;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                                overflow: elide;
                            }
                            Rectangle {
                                width: 56px;
                                height: 18px;
                                border-radius: 9px;
                                background: Theme.btn;
                                Text {
                                    text: root.schedule-empty ? "규칙 없음" : "규칙 있음";
                                    color: Theme.text-lo;
                                    font-size: 10px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                            Text {
                                text: root.auto-mode-expanded ? "▲" : "▼";
                                color: Theme.text-lo;
                                font-size: 11px;
                                vertical-alignment: center;
                            }
                        }

                        Text {
                            text: root.schedule-empty
                                ? "시간대별 자동 최적화 (앱 실행 중에만 동작)"
                                : root.active-rule-info;
                            color: Theme.text-desc;
                            font-size: 10px;
                            overflow: elide;
                            horizontal-stretch: 1;
                        }
                    }
                    Rectangle {
                        background: Theme.text-hi;
                        opacity: auto-ta.has-hover ? 0.04 : 0.0;
                        animate opacity { duration: 150ms; easing: ease-out; }
                    }
                    auto-ta := ClickableSurface {
                        width: 100%;
                        height: 100%;
                        accessible-label-text: root.auto-mode-expanded ? "자동 모드 접기" : "자동 모드 펼치기";
                        clicked => { root.auto-mode-expanded = !root.auto-mode-expanded; }
                    }
                }

                Rectangle {
                    clip: true;
                    height: root.auto-mode-expanded ? auto-content.preferred-height : 0px;
                    animate height { duration: 280ms * Theme.motion-scale; easing: cubic-bezier(0.16, 1, 0.3, 1); }
                    auto-content := VerticalLayout {
                    width: 100%;
                    padding-left: 12px;
                    padding-right: 12px;
                    padding-bottom: 12px;
                    spacing: 8px;

                    LineEdit {
                        text: root.new-rule-name;
                        placeholder-text: "규칙 이름 (예: 게임 시간 고성능)";
                        edited(t) => { root.new-rule-name = t; }
                    }

                    HorizontalLayout {
                        spacing: 6px;
                        kind-cb := ComboBox {
                            model: ["매일", "평일", "주말", "특정 날짜"];
                            horizontal-stretch: 1;
                            selected(v) => {
                                if (self.current-index == 0) { root.new-rule-kind = RuleKind.daily; }
                                else if (self.current-index == 1) { root.new-rule-kind = RuleKind.weekday; }
                                else if (self.current-index == 2) { root.new-rule-kind = RuleKind.weekend; }
                                else { root.new-rule-kind = RuleKind.specific; }
                            }
                        }
                        if root.new-rule-kind == RuleKind.specific : LineEdit {
                            text: root.new-rule-date;
                            placeholder-text: "YYYY-MM-DD";
                            horizontal-stretch: 1;
                            edited(t) => { root.new-rule-date = t; }
                        }
                    }

                    HorizontalLayout {
                        spacing: 6px;
                        LineEdit {
                            placeholder-text: "시작 HH:MM";
                            text: root.new-rule-start;
                            horizontal-stretch: 1;
                            edited(t) => { root.new-rule-start = t; }
                        }
                        LineEdit {
                            placeholder-text: "종료 HH:MM";
                            text: root.new-rule-end;
                            horizontal-stretch: 1;
                            edited(t) => { root.new-rule-end = t; }
                        }
                        mode-cb := ComboBox {
                            model: ["고성능", "일반", "저전력"];
                            horizontal-stretch: 1;
                            selected(v) => {
                                if (self.current-index == 0) { root.new-rule-mode = OptimizeMode.high; }
                                else if (self.current-index == 1) { root.new-rule-mode = OptimizeMode.normal; }
                                else { root.new-rule-mode = OptimizeMode.low_power; }
                            }
                        }
                    }

                    DBtn {
                        text: "+ 규칙 추가";
                        base-color: Theme.btn-sched;
                        hover-color: Theme.btn-sched-h;
                        text-color: Theme.text-btn-sched;
                        grad-1: Theme.btn-primary-1;
                        grad-2: Theme.btn-primary-2;
                        grad-h-1: Theme.btn-primary-2;
                        grad-h-2: Theme.btn-primary-1;
                        clicked => { root.add-schedule-rule(); }
                    }

                    Rectangle {
                        height: 1px;
                        background: Theme.panel-bd;
                    }

                    if root.schedule-empty : Text {
                        text: "아직 등록된 규칙이 없습니다.";
                        color: Theme.text-lo;
                        font-size: 12px;
                        horizontal-alignment: center;
                    }

                    if !root.schedule-empty : VerticalLayout {
                        spacing: 4px;
                        for rule in root.schedule-rules : Rectangle {
                            property <float> row-fade: 0.0;
                            property <length> row-slide: 8px;
                            opacity: row-fade;
                            x: row-slide;
                            animate row-fade { duration: 320ms * Theme.motion-scale; easing: cubic-bezier(0.16, 1, 0.3, 1); }
                            animate row-slide { duration: 320ms * Theme.motion-scale; easing: cubic-bezier(0.16, 1, 0.3, 1); }
                            init => { row-fade = 1.0; row-slide = 0px; }
                            height: 34px;
                            background: Theme.row;
                            border-radius: 5px;
                            border-width: 1px;
                            border-color: rule.active ? Theme.row-act-bd : Theme.row-inact-bd;

                            HorizontalLayout {
                                padding-left: 10px;
                                padding-right: 6px;
                                spacing: 8px;
                                alignment: center;

                                Text {
                                    text: rule.summary;
                                    color: rule.active ? Theme.row-act-tx : Theme.row-inact-tx;
                                    font-size: 12px;
                                    vertical-alignment: center;
                                    overflow: elide;
                                    horizontal-stretch: 1;
                                }

                                ToggleSwitch {
                                    checked: rule.active;
                                    toggled => { root.toggle-schedule-rule(rule.id); }
                                }

                                Rectangle {
                                    width: 28px;
                                    height: 28px;
                                    border-radius: 4px;
                                    background: del.has-hover ? Theme.del-bg-h : Theme.del-bg;
                                    animate background { duration: 120ms; easing: ease-out; }
                                    Text {
                                        text: "X";
                                        color: Theme.del-text;
                                        font-size: 12px;
                                        font-weight: 700;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                    del := ClickableSurface {
                                        width: 100%;
                                        height: 100%;
                                        accessible-label-text: "규칙 삭제";
                                        clicked => { root.delete-schedule-rule(rule.id); }
                                    }
                                }
                            }
                        }
                    }
                    }
                }
            }
            z: 2;
            s1_tip := HelpTooltip {
                x: parent.width - 26px;
                y: 10px;
                text: "시간대별로 성능 모드를 자동 전환하는 규칙을 등록합니다.";
            }
        }

        Rectangle {
            vertical-stretch: 0;
            border-radius: 8px;
            border-width: 1px;
            border-color: Theme.acc-sd-bd;
            background: Theme.acc-sd-bg;
            animate background { duration: 220ms * Theme.motion-scale; easing: ease; }
            animate border-color { duration: 220ms * Theme.motion-scale; easing: ease; }

            Rectangle {
                width: 100%; height: 100%;
                border-radius: 8px;
                border-width: 2px;
                border-color: #27ae60;
                background: transparent;
                opacity: root.shutdown-once-active || root.shutdown-weekly-active
                    ? 1.0
                    : Math.min(1.0, root.shutdown-flash);
            }

            VerticalLayout {
                alignment: start;
                Rectangle {
                    height: 58px;
                    background: transparent;

                    VerticalLayout {
                        padding-left: 12px;
                        padding-right: 12px;
                        padding-top: 8px;
                        padding-bottom: 7px;
                        spacing: 3px;

                        HorizontalLayout {
                            spacing: 8px;
                            alignment: center;

                            Text { text: "⚠️"; font-size: 14px; vertical-alignment: center; }
                            Text {
                                text: "PC 예약 종료";
                                color: Theme.acc-sd-title;
                                font-size: 13px;
                                font-weight: 700;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }
                            VerticalLayout {
                                alignment: center;
                                Rectangle {
                                    width: 56px;
                                    height: 18px;
                                    border-radius: 9px;
                                    background: Theme.acc-sd-pill-bg;
                                    Text {
                                        text: "전원 차단";
                                        color: Theme.acc-sd-pill-tx;
                                        font-size: 10px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                            Text {
                                text: root.shutdown-expanded ? "▲" : "▼";
                                color: Theme.acc-sd-title;
                                font-size: 11px;
                                vertical-alignment: center;
                            }
                        }

                        if !root.shutdown-once-active && !root.shutdown-weekly-active : Text {
                            text: "앱 종료 후에도 Windows 작업 스케줄러가 실행됩니다.";
                            color: Theme.text-desc;
                            font-size: 10px;
                            overflow: elide;
                            animate color { duration: 300ms * Theme.motion-scale; easing: ease; }
                        }
                        if root.shutdown-once-active : Text {
                            text: "● " + root.shutdown-once-text;
                            color: #27ae60;
                            font-size: 10px;
                            overflow: elide;
                            animate color { duration: 300ms * Theme.motion-scale; easing: ease; }
                        }
                        if root.shutdown-weekly-active : Text {
                            text: "● " + root.shutdown-weekly-text;
                            color: #27ae60;
                            font-size: 10px;
                            overflow: elide;
                            animate color { duration: 300ms * Theme.motion-scale; easing: ease; }
                        }
                    }
                    Rectangle {
                        background: Theme.acc-sd-title;
                        opacity: sd-ta.has-hover ? 0.06 : 0.0;
                        animate opacity { duration: 150ms; easing: ease-out; }
                    }
                    sd-ta := ClickableSurface {
                        width: 100%;
                        height: 100%;
                        accessible-label-text: root.shutdown-expanded ? "PC 예약 종료 접기" : "PC 예약 종료 펼치기";
                        clicked => { root.shutdown-expanded = !root.shutdown-expanded; }
                    }
                }

                Rectangle {
                    clip: true;
                    height: root.shutdown-expanded ? shutdown-content.preferred-height : 0px;
                    animate height { duration: 280ms * Theme.motion-scale; easing: cubic-bezier(0.16, 1, 0.3, 1); }
                    shutdown-content := VerticalLayout {
                    width: 100%;
                    alignment: start;
                    padding-left: 12px;
                    padding-right: 12px;
                    padding-bottom: 12px;
                    spacing: 8px;

                    Rectangle {
                        height: 32px;
                        border-radius: 5px;
                        border-width: 1px;
                        border-color: Theme.acc-sd-bd;

                        HorizontalLayout {
                            Rectangle {
                                horizontal-stretch: 1;
                                background: !root.shutdown-weekly ? Theme.acc-sd-pill-bg : Theme.acc-sd-bg;
                                Rectangle {
                                    background: #ffffff;
                                    opacity: (root.shutdown-weekly && seg-once-ta.has-hover) ? 0.06 : 0.0;
                                    animate opacity { duration: 120ms; easing: ease-out; }
                                }
                                Text {
                                    text: "단발 종료";
                                    color: !root.shutdown-weekly ? Theme.acc-sd-title : Theme.text-lo;
                                    font-size: 12px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                                seg-once-ta := ClickableSurface {
                                    width: 100%;
                                    height: 100%;
                                    accessible-label-text: "단발 종료 선택";
                                    clicked => { root.shutdown-weekly = false; }
                                }
                            }
                            Rectangle {
                                horizontal-stretch: 1;
                                background: root.shutdown-weekly ? Theme.acc-sd-pill-bg : Theme.acc-sd-bg;
                                Rectangle {
                                    background: #ffffff;
                                    opacity: (!root.shutdown-weekly && seg-weekly-ta.has-hover) ? 0.06 : 0.0;
                                    animate opacity { duration: 120ms; easing: ease-out; }
                                }
                                Text {
                                    text: "매주 반복";
                                    color: root.shutdown-weekly ? Theme.acc-sd-title : Theme.text-lo;
                                    font-size: 12px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                                seg-weekly-ta := ClickableSurface {
                                    width: 100%;
                                    height: 100%;
                                    accessible-label-text: "매주 반복 선택";
                                    clicked => { root.shutdown-weekly = true; }
                                }
                            }
                        }
                    }

                    if !root.shutdown-weekly : VerticalLayout {
                        vertical-stretch: 0;
                        spacing: 4px;
                        Rectangle {
                            height: 36px;
                            border-radius: 6px;
                            background: Theme.btn;
                            border-color: root.cal-open ? #4a90e8 : Theme.btn-bd;
                            border-width: 1px;
                            animate border-color { duration: 150ms; easing: ease; }
                            HorizontalLayout {
                                padding-left: 8px;
                                padding-right: 8px;
                                spacing: 8px;
                                alignment: center;
                                Text { text: "📅"; font-size: 14px; vertical-alignment: center; }
                                Text {
                                    text: root.cal-selected-label;
                                    color: #7fb8ff;
                                    font-size: 12px;
                                    font-weight: 600;
                                    horizontal-stretch: 1;
                                    vertical-alignment: center;
                                }
                                Text {
                                    text: root.cal-open ? "▲" : "▼";
                                    color: Theme.text-lo;
                                    font-size: 10px;
                                    vertical-alignment: center;
                                }
                            }
                            ClickableSurface {
                                accessible-label-text: root.cal-open ? "달력 접기" : "달력 펼치기";
                                clicked => { root.cal-open = !root.cal-open; }
                            }
                        }
                        if root.cal-open : CalendarPicker {
                            days: root.cal-days;
                            month-label: root.cal-month-label;
                            selected-day: root.cal-selected-day;
                            today-day: root.cal-today-day;
                            prev-month => { root.cal-prev-month(); }
                            next-month => { root.cal-next-month(); }
                            day-selected(d) => { root.cal-select-day(d); }
                        }
                    }

                    if root.shutdown-weekly : HorizontalLayout {
                        vertical-stretch: 0;
                        spacing: 6px;
                        alignment: center;
                        WeekdayChip { text: "월"; selected <=> root.shutdown-mon; }
                        WeekdayChip { text: "화"; selected <=> root.shutdown-tue; }
                        WeekdayChip { text: "수"; selected <=> root.shutdown-wed; }
                        WeekdayChip { text: "목"; selected <=> root.shutdown-thu; }
                        WeekdayChip { text: "금"; selected <=> root.shutdown-fri; }
                        WeekdayChip { text: "토"; selected <=> root.shutdown-sat; }
                        WeekdayChip { text: "일"; selected <=> root.shutdown-sun; }
                    }

                    VerticalLayout {
                        vertical-stretch: 0;
                        spacing: 4px;
                        Text {
                            vertical-stretch: 0;
                            text: "종료 시간";
                            color: Theme.text-lo;
                            font-size: 10px;
                            font-weight: 700;
                            letter-spacing: 0.5px;
                        }
                        TimePicker {
                            vertical-stretch: 0;
                            hour-text: root.shutdown-hour-text;
                            minute-text: root.shutdown-minute-text;
                            hour-up => { root.shutdown-hour-up(); }
                            hour-down => { root.shutdown-hour-down(); }
                            minute-up => { root.shutdown-minute-up(); }
                            minute-down => { root.shutdown-minute-down(); }
                            hour-edited(t) => { root.shutdown-hour-set(t); }
                            minute-edited(t) => { root.shutdown-minute-set(t); }
                        }
                    }

                    Rectangle {
                        vertical-stretch: 0;
                        height: 12px;
                    }

                    TwoButtonRow {
                        vertical-stretch: 0;
                        left-text: "예약 등록";
                        right-text: "예약 취소";
                        left-base-color: Theme.btn-sd-reg;
                        left-hover-color: Theme.btn-sd-reg-h;
                        left-text-color: Theme.text-btn-sd-reg;
                        left-grad-1: Theme.btn-warn-1;
                        left-grad-2: Theme.btn-warn-2;
                        left-grad-h-1: Theme.btn-warn-2;
                        left-grad-h-2: Theme.btn-warn-1;
                        right-base-color: Theme.btn-cancel;
                        right-hover-color: Theme.btn-cancel-h;
                        right-text-color: Theme.text-btn-cancel;
                        right-grad-1: Theme.btn-dan-1;
                        right-grad-2: Theme.btn-dan-2;
                        right-grad-h-1: Theme.btn-dan-2;
                        right-grad-h-2: Theme.btn-dan-1;
                        left-clicked => { root.register-shutdown(); }
                        right-clicked => {
                            if (root.shutdown-weekly) {
                                root.cancel-weekly-shutdown();
                            } else {
                                root.cancel-once-shutdown();
                            }
                        }
                    }
                }
                }
            }
            z: 1;
            s2_tip := HelpTooltip {
                x: parent.width - 26px;
                y: 10px;
                text: "지정한 시각에 PC를 자동으로 종료합니다. 단발 또는 매주 반복.";
            }
        }
    }
}
