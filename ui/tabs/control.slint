import { ScrollView } from "std-widgets.slint";
import { Theme, OptimizeMode } from "../theme.slint";
import { SectionHeader, HelpTooltip } from "../widgets.slint";
import { OptimizeRow, TwoButtonRow } from "../buttons.slint";

component StatusTile inherits Rectangle {
    in property <string> label;
    in property <string> value;
    // M89-1: 두 번째 줄 값(자동 종료 요약 등). 빈 문자열이면 Text 부재.
    in property <string> secondary-value: "";
    in property <bool> active;
    in property <color> accent-color;
    in property <float> pulse-phase;
    in property <float> pulse-offset;

    // M89-1: secondary 영역 확보로 64→80px. 모든 타일 균일.
    height: 80px;
    preferred-width: 0px;
    // M89-4: active 시 미세 sin breath. ±0.04 alpha-equivalent.
    // motion-scale 곱셈으로 reduce-motion 존중. cycle ~2500ms 효과(pulse-phase 1°/ms 기준).
    property <float> breath: root.active
        ? (1.0 + 0.04 * Theme.motion-scale * Math.sin((root.pulse-phase + root.pulse-offset) * 0.4 * 1deg))
        : 1.0;
    background: Theme.dark ? #11151d : #f7f9fa;
    opacity: root.breath;
    border-radius: 6px;
    border-width: 1px;
    border-color: Theme.dark ? #252b35 : #d9e0e4;
    animate background { duration: 220ms * Theme.motion-scale; easing: ease; }
    animate border-color { duration: 220ms * Theme.motion-scale; easing: ease; }

    VerticalLayout {
        padding-left: 10px;
        padding-right: 10px;
        padding-top: 8px;
        padding-bottom: 8px;
        spacing: 4px;

        // M88: dot은 10x10 고정, label은 stretch. dot/label 좌측 정렬 + 수직 중앙.
        // 기존 `alignment: center`는 dot+label 그룹을 가로 중앙으로 밀어내 어색했다.
        HorizontalLayout {
            height: 18px;
            spacing: 7px;

            VerticalLayout {
                alignment: center;
                Rectangle {
                    width: 10px;
                    height: 10px;
                    border-radius: 5px;
                    background: root.active ? root.accent-color : (Theme.dark ? #5c6470 : #9aa5ad);
                    opacity: root.active
                        ? ((Theme.dark ? 0.90 : 0.80) + 0.10 * Theme.motion-scale * Math.sin((root.pulse-phase + root.pulse-offset) * 1deg))
                        : 0.56;
                    animate background { duration: 300ms * Theme.motion-scale; easing: ease; }
                    animate opacity { duration: 300ms * Theme.motion-scale; easing: ease; }
                }
            }

            Text {
                text: root.label;
                color: Theme.text-lo;
                font-size: 11px;
                font-weight: 700;
                horizontal-stretch: 1;
                vertical-alignment: center;
                overflow: elide;
            }
        }

        Text {
            text: root.value;
            color: root.active ? root.accent-color : Theme.text-hi;
            font-size: 14px;
            font-weight: 700;
            horizontal-stretch: 1;
            overflow: elide;
            animate color { duration: 300ms * Theme.motion-scale; easing: ease; }
        }

        // M89-1: secondary value (자동 종료 요약 등) — 빈 문자열이면 미표시.
        if root.secondary-value != "" : Text {
            text: root.secondary-value;
            color: Theme.text-desc;
            font-size: 10px;
            font-weight: 500;
            horizontal-stretch: 1;
            overflow: elide;
            opacity: 0.85;
        }
    }
}

export component ControlTab inherits ScrollView {
    in property <bool> admin-ok;
    in property <bool> game-running;
    // M79 (MA-C2): enum + bool로 타입 안전 비교. label은 derived(아래 current-mode-label).
    in property <OptimizeMode> current-mode;
    in property <bool> current-mode-known;
    in property <bool> schedule-empty;
    in property <string> active-rule-info;
    in property <float> pulse-phase;
    in property <float> mode-ripple;
    // M89-1: 스케줄 타일에 자동 종료 요약 표시용. app.slint에서 binding.
    in property <bool> shutdown-once-active;
    in property <string> shutdown-once-text;
    in property <bool> shutdown-weekly-active;
    in property <string> shutdown-weekly-text;
    callback refresh-game-status();
    callback launch-game();
    callback apply-high-mode();
    callback apply-normal-mode();
    callback apply-low-power-mode();

    // M79: pill 표시용 derived 라벨. Rust mode_label과 문구만 일관 유지.
    property <string> current-mode-label:
        root.current-mode == OptimizeMode.high ? "고성능 모드"
      : root.current-mode == OptimizeMode.normal ? "일반 모드"
      : "저전력 모드";

    // M89-1: 자동 종료 요약(단발 우선, 둘 다 비활성이면 빈 문자열).
    // 스케줄 타일 secondary-value로 전달.
    property <string> schedule-secondary:
        root.shutdown-once-active ? root.shutdown-once-text
      : root.shutdown-weekly-active ? root.shutdown-weekly-text
      : "";

    vertical-stretch: 1;
    property <float> tab-fade: 0.0;
    property <length> tab-slide: 18px;
    opacity: tab-fade;
    x: tab-slide;
    // M89-3: 탭 진입 더 명확 — fade 240→400ms, slide 320→480ms.
    animate tab-fade { duration: 400ms * Theme.motion-scale; easing: cubic-bezier(0.16, 1, 0.3, 1); }
    animate tab-slide { duration: 480ms * Theme.motion-scale; easing: cubic-bezier(0.16, 1, 0.3, 1); }
    init => { tab-fade = 1.0; tab-slide = 0px; }

    VerticalLayout {
        padding: 16px;
        spacing: 10px;
        width: parent.width;
        alignment: start;

        if !root.admin-ok : Rectangle {
            background: Theme.dark ? #1e0808 : #fff0f0;
            border-radius: 7px;
            border-width: 1px;
            border-color: #c0392b;
            animate background { duration: 220ms * Theme.motion-scale; easing: ease; }

            HorizontalLayout {
                padding: 10px;
                spacing: 10px;
                alignment: center;
                Text { text: "⚠️"; font-size: 16px; vertical-alignment: center; }
                Text {
                    text: "관리자 권한 없음 — 최적화·예약 종료 기능이 제한됩니다. 앱을 우클릭 → 관리자로 실행하세요.";
                    color: Theme.dark ? #ff8080 : #c0392b;
                    font-size: 12px;
                    wrap: word-wrap;
                    horizontal-stretch: 1;
                    vertical-alignment: center;
                }
            }
        }

        Rectangle {
            background: @linear-gradient(135deg, Theme.card-grad-1 0%, Theme.card-grad-2 100%);
            border-radius: 8px;
            border-width: 1px;
            border-color: Theme.panel-bd;
            animate background { duration: 220ms * Theme.motion-scale; easing: ease; }
            animate border-color { duration: 220ms * Theme.motion-scale; easing: ease; }

            VerticalLayout {
                padding: 12px;
                spacing: 8px;

                HorizontalLayout {
                    spacing: 8px;

                    StatusTile {
                        horizontal-stretch: 1;
                        label: "권한";
                        value: root.admin-ok ? "획득" : "없음";
                        active: root.admin-ok;
                        accent-color: root.admin-ok ? #27ae60 : #c0392b;
                        pulse-phase: root.pulse-phase;
                        pulse-offset: 0;
                    }

                    StatusTile {
                        horizontal-stretch: 1;
                        label: "게임";
                        value: root.game-running ? "실행 중" : "미실행";
                        active: root.game-running;
                        accent-color: #27ae60;
                        pulse-phase: root.pulse-phase;
                        pulse-offset: 90;
                    }
                }

                HorizontalLayout {
                    spacing: 8px;

                    StatusTile {
                        horizontal-stretch: 1;
                        label: "모드";
                        value: root.current-mode-known ? root.current-mode-label : "알 수 없음";
                        active: root.current-mode-known;
                        accent-color: Theme.btn-primary-1;
                        pulse-phase: root.pulse-phase;
                        pulse-offset: 180;
                    }

                    StatusTile {
                        horizontal-stretch: 1;
                        label: "스케줄";
                        value: root.schedule-empty ? "규칙 없음" : root.active-rule-info;
                        secondary-value: root.schedule-secondary;
                        active: !root.schedule-empty || root.shutdown-once-active || root.shutdown-weekly-active;
                        accent-color: #7c8dff;
                        pulse-phase: root.pulse-phase;
                        pulse-offset: 270;
                    }
                }
            }
        }

        Rectangle {
            background: @linear-gradient(135deg, Theme.card-grad-1 0%, Theme.card-grad-2 100%);
            border-radius: 8px;
            border-width: 1px;
            border-color: Theme.panel-bd;
            animate background { duration: 220ms * Theme.motion-scale; easing: ease; }
            animate border-color { duration: 220ms * Theme.motion-scale; easing: ease; }

            VerticalLayout {
                padding: 12px;
                spacing: 7px;

                SectionHeader {
                    label: "GAME";
                    desc: "런처 실행과 프로세스 상태를 관리합니다.";
                }

                TwoButtonRow {
                    left-text: "상태 새로고침";
                    right-text: "게임 실행";
                    left-grad-1: Theme.btn-sec-1;
                    left-grad-2: Theme.btn-sec-2;
                    left-grad-h-1: Theme.btn-sec-2;
                    left-grad-h-2: Theme.btn-sec-1;
                    right-base-color: Theme.btn-game;
                    right-hover-color: Theme.btn-game-h;
                    right-text-color: Theme.text-btn-game;
                    right-grad-1: Theme.btn-primary-1;
                    right-grad-2: Theme.btn-primary-2;
                    right-grad-h-1: Theme.btn-primary-2;
                    right-grad-h-2: Theme.btn-primary-1;
                    left-clicked => { root.refresh-game-status(); }
                    right-clicked => { root.launch-game(); }
                }
            }
            z: 2;
            c2_tip := HelpTooltip {
                x: parent.width - 26px;
                y: 10px;
                text: "검은사막 런처를 탐색해 실행합니다.";
            }
        }

        Rectangle {
            background: @linear-gradient(135deg, Theme.card-grad-1 0%, Theme.card-grad-2 100%);
            border-radius: 8px;
            border-width: 1px;
            border-color: Theme.panel-bd;
            animate background { duration: 220ms * Theme.motion-scale; easing: ease; }
            animate border-color { duration: 220ms * Theme.motion-scale; easing: ease; }

            VerticalLayout {
                padding: 12px;
                spacing: 7px;

                SectionHeader {
                    label: "MODE";
                    desc: "BlackDesert64.exe 우선순위와 CPU affinity를 즉시 적용합니다.";
                }

                OptimizeRow {
                    // M79 (MA-C1): enabled 분기로 click/key/스크린리더 가드.
                    // 외곽 opacity tone-down은 OptimizeRow 내부에서 처리.
                    enabled: root.admin-ok && root.game-running;
                    high-active: root.game-running && root.current-mode-known
                        && root.current-mode == OptimizeMode.high;
                    normal-active: root.game-running && root.current-mode-known
                        && root.current-mode == OptimizeMode.normal;
                    low-power-active: root.game-running && root.current-mode-known
                        && root.current-mode == OptimizeMode.low_power;
                    pulse-phase: root.pulse-phase;
                    ripple-opacity: root.mode-ripple;
                    high-clicked => { root.apply-high-mode(); }
                    normal-clicked => { root.apply-normal-mode(); }
                    low-power-clicked => { root.apply-low-power-mode(); }
                }

                if !(root.admin-ok && root.game-running) : Text {
                    text: !root.admin-ok
                        ? "관리자 권한이 없어 최적화를 적용할 수 없습니다."
                        : "게임 실행 후 사용 가능합니다.";
                    color: !root.admin-ok ? (Theme.dark ? #ff8080 : #c0392b) : Theme.text-desc;
                    font-size: 11px;
                    horizontal-alignment: center;
                }

                Text {
                    text: "고성능: 물리 코어 + High 우선순위   |   일반: 전체 코어 + Normal   |   저전력: 마지막 코어 + Idle";
                    color: Theme.text-desc;
                    font-size: 11px;
                    wrap: word-wrap;
                }
            }
            z: 1;
            c3_tip := HelpTooltip {
                x: parent.width - 26px;
                y: 10px;
                text: "검은사막의 성능 모드(고성능/일반/저전력)를 즉시 변경합니다.";
            }
        }
    }
}
