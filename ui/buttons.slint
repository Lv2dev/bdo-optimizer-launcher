import { Theme } from "theme.slint";

// M79 (MA-C3): transparent 클릭 영역. raw TouchArea가 a11y/키보드 누락한 6곳을
// 대체한다. accessible-role: button + accessible-label-text 노출 + FocusScope
// outline + Enter/Space 핸들링. hover overlay는 호출자가 별도 표시(행 X 삭제
// 빨강 vs 카드 헤더 회색 등 색상 다양성 유지). has-hover/has-focus 노출.
export component ClickableSurface inherits Rectangle {
    in property <bool>   enabled: true;
    in property <string> accessible-label-text;
    callback clicked;

    out property <bool>  has-hover: cs-ta.has-hover;
    out property <bool>  has-focus: cs-fs.has-focus;

    accessible-role: button;
    accessible-label: root.accessible-label-text + (root.enabled ? "" : " (비활성)");
    accessible-action-default => { if (root.enabled) { root.clicked(); } }

    background: transparent;

    Rectangle {
        x: 0; y: 0;
        width: parent.width;
        height: parent.height;
        border-radius: parent.border-radius;
        border-width: 2px;
        border-color: Theme.tgl-on;
        background: transparent;
        opacity: cs-fs.has-focus ? 0.9 : 0.0;
        animate opacity { duration: 150ms; easing: ease-out; }
    }
    cs-fs := FocusScope {
        width: 100%;
        height: 100%;
        key-pressed(event) => {
            if (root.enabled && (event.text == Key.Return || event.text == Key.Space)) {
                root.clicked();
                return accept;
            }
            return reject;
        }
    }
    cs-ta := TouchArea {
        width: 100%;
        height: 100%;
        enabled: root.enabled;
        clicked => { cs-fs.focus(); root.clicked(); }
    }
}

export component DBtn inherits Rectangle {
    in property <string> text;
    in property <string> accessible-label-text;
    in property <color>  base-color: Theme.btn;
    in property <color>  hover-color: Theme.btn-h;
    in property <color>  text-color: Theme.text-hi;
    in property <color>  grad-1: #00000000;
    in property <color>  grad-2: #00000000;
    in property <color>  grad-h-1: #00000000;
    in property <color>  grad-h-2: #00000000;
    in property <color>  border-c: Theme.btn-bd;
    // M79: 비활성 시 opacity 0.42 + click/key/스크린리더 차단. ToggleSwitch M65 패턴 재사용.
    in property <bool>   enabled: true;
    callback clicked;

    accessible-role: button;
    accessible-label: (root.accessible-label-text != "" ? root.accessible-label-text : root.text)
        + (root.enabled ? "" : " (비활성)");
    accessible-action-default => { if (root.enabled) { root.clicked(); } }

    property <bool> use-grad: root.grad-1 != #00000000 && root.grad-2 != #00000000;

    height: 36px;
    preferred-width: 0px;
    border-radius: 8px;
    border-width: 1px;
    border-color: root.border-c;
    background: ta.has-hover ? hover-color : base-color;
    opacity: root.enabled ? 1.0 : 0.42;
    clip: true;
    animate background { duration: 150ms; easing: ease-out; }
    animate border-color { duration: 150ms; easing: ease-out; }
    animate opacity { duration: 200ms; easing: ease-out; }

    if root.use-grad : Rectangle {
        x: 1px; y: 1px;
        width: parent.width - 2px;
        height: parent.height - 2px;
        border-radius: 7px;
        background: ta.has-hover
            ? @linear-gradient(135deg, root.grad-h-1 0%, root.grad-h-2 100%)
            : @linear-gradient(135deg, root.grad-1 0%, root.grad-2 100%);
        animate background { duration: 150ms; easing: ease-out; }
    }

    Rectangle {
        x: 1px; y: 1px;
        width: parent.width - 2px;
        height: parent.height - 2px;
        border-radius: 7px;
        background: ta.pressed ? #000000 : #ffffff;
        opacity: ta.pressed ? 0.10 : (ta.has-hover ? 0.08 : 0.0);
        animate opacity { duration: 150ms; easing: ease-out; }
        animate background { duration: 150ms; easing: ease-out; }
    }

    Text {
        width: 100%;
        height: 100%;
        text: root.text;
        color: root.text-color;
        font-size: 13px;
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
    // 키보드 포커스 가시 단서: 내부 2px outline. fs.has-focus 시 표시.
    Rectangle {
        x: 0; y: 0;
        width: parent.width;
        height: parent.height;
        border-radius: parent.border-radius;
        border-width: 2px;
        border-color: Theme.tgl-on;
        background: transparent;
        opacity: fs.has-focus ? 0.9 : 0.0;
        animate opacity { duration: 150ms; easing: ease-out; }
    }
    fs := FocusScope {
        width: 100%;
        height: 100%;
        key-pressed(event) => {
            if (root.enabled && (event.text == Key.Return || event.text == Key.Space)) {
                root.clicked();
                return accept;
            }
            return reject;
        }
    }
    ta := TouchArea {
        width: 100%;
        height: 100%;
        enabled: root.enabled;
        clicked => { fs.focus(); root.clicked(); }
    }
}

export component TwoButtonRow inherits Rectangle {
    in property <string> left-text;
    in property <string> right-text;
    in property <color> left-base-color: Theme.btn;
    in property <color> left-hover-color: Theme.btn-h;
    in property <color> left-text-color: Theme.text-hi;
    in property <color> right-base-color: Theme.btn;
    in property <color> right-hover-color: Theme.btn-h;
    in property <color> right-text-color: Theme.text-hi;
    in property <color> left-grad-1: #00000000;
    in property <color> left-grad-2: #00000000;
    in property <color> left-grad-h-1: #00000000;
    in property <color> left-grad-h-2: #00000000;
    in property <color> left-border-c: Theme.btn-bd;
    in property <color> right-grad-1: #00000000;
    in property <color> right-grad-2: #00000000;
    in property <color> right-grad-h-1: #00000000;
    in property <color> right-grad-h-2: #00000000;
    in property <color> right-border-c: Theme.btn-bd;
    in property <length> gap: 8px;
    callback left-clicked;
    callback right-clicked;

    height: 36px;

    left-button := DBtn {
        x: 0px;
        y: 0px;
        width: (root.width - root.gap) / 2;
        height: root.height;
        text: root.left-text;
        base-color: root.left-base-color;
        hover-color: root.left-hover-color;
        text-color: root.left-text-color;
        grad-1: root.left-grad-1;
        grad-2: root.left-grad-2;
        grad-h-1: root.left-grad-h-1;
        grad-h-2: root.left-grad-h-2;
        border-c: root.left-border-c;
        clicked => { root.left-clicked(); }
    }

    right-button := DBtn {
        x: left-button.width + root.gap;
        y: 0px;
        width: (root.width - root.gap) / 2;
        height: root.height;
        text: root.right-text;
        base-color: root.right-base-color;
        hover-color: root.right-hover-color;
        text-color: root.right-text-color;
        grad-1: root.right-grad-1;
        grad-2: root.right-grad-2;
        grad-h-1: root.right-grad-h-1;
        grad-h-2: root.right-grad-h-2;
        border-c: root.right-border-c;
        clicked => { root.right-clicked(); }
    }
}

export component ToggleSwitch inherits Rectangle {
    in property <bool> checked;
    // M65: 비활성 시 opacity 0.4 + click/key 차단. 의존 토글(자동 시작 OFF → 트레이 시작 비활성)에 사용.
    in property <bool> enabled: true;
    in property <string> accessible-label-text: "토글";
    callback toggled;

    accessible-role: checkbox;
    accessible-label: root.accessible-label-text;
    accessible-checkable: true;
    accessible-checked: root.checked;
    accessible-action-default => { if (root.enabled) { root.toggled(); } }

    width: 38px;
    height: 22px;
    border-radius: 11px;
    background: checked ? #27ae60 : Theme.tgl-off;
    opacity: root.enabled ? 1.0 : 0.4;
    animate background { duration: 180ms; easing: ease-out; }
    animate opacity { duration: 150ms; easing: ease-out; }

    Rectangle {
        width: 16px;
        height: 16px;
        border-radius: 8px;
        background: #ffffff;
        y: 3px;
        x: checked ? (parent.width - self.width - 3px) : 3px;
        animate x { duration: 180ms; easing: ease-out; }
    }
    Rectangle {
        x: 0; y: 0;
        width: parent.width;
        height: parent.height;
        border-radius: parent.border-radius;
        border-width: 2px;
        border-color: Theme.tgl-on;
        background: transparent;
        opacity: ts-fs.has-focus ? 0.9 : 0.0;
        animate opacity { duration: 150ms; easing: ease-out; }
    }
    ts-fs := FocusScope {
        width: 100%;
        height: 100%;
        key-pressed(event) => {
            if (root.enabled && (event.text == Key.Return || event.text == Key.Space)) {
                root.toggled();
                return accept;
            }
            return reject;
        }
    }
    TouchArea {
        width: 100%;
        height: 100%;
        enabled: root.enabled;
        clicked => { ts-fs.focus(); root.toggled(); }
    }
}

// 요일 선택 칩: 28x28 원형, 선택 시 청록 배경 + 글자 강조. FocusScope + Enter/Space로 토글.
export component WeekdayChip inherits Rectangle {
    in property <string> text;
    in-out property <bool> selected;
    callback toggled;

    accessible-role: checkbox;
    accessible-label: root.text;
    accessible-checkable: true;
    accessible-checked: root.selected;
    accessible-action-default => { root.selected = !root.selected; root.toggled(); }

    width: 28px;
    height: 28px;
    border-radius: 14px;
    border-width: 1px;
    border-color: root.selected ? Theme.tgl-on : Theme.panel-bd;
    background: root.selected ? Theme.tgl-on : Theme.panel;
    animate background { duration: 150ms; easing: ease-out; }
    animate border-color { duration: 150ms; easing: ease-out; }

    Rectangle {
        x: 0; y: 0;
        width: parent.width;
        height: parent.height;
        border-radius: parent.border-radius;
        background: Theme.text-hi;
        opacity: ta.has-hover && !root.selected ? 0.06 : 0.0;
        animate opacity { duration: 150ms; easing: ease-out; }
    }
    Text {
        width: 100%;
        height: 100%;
        text: root.text;
        color: root.selected ? #ffffff : Theme.text-lo;
        font-size: 12px;
        font-weight: root.selected ? 700 : 500;
        horizontal-alignment: center;
        vertical-alignment: center;
        animate color { duration: 150ms; easing: ease-out; }
    }
    Rectangle {
        x: 0; y: 0;
        width: parent.width;
        height: parent.height;
        border-radius: parent.border-radius;
        border-width: 2px;
        border-color: Theme.tgl-on;
        background: transparent;
        opacity: wc-fs.has-focus ? 0.9 : 0.0;
        animate opacity { duration: 150ms; easing: ease-out; }
    }
    wc-fs := FocusScope {
        width: 100%;
        height: 100%;
        key-pressed(event) => {
            if (event.text == Key.Return || event.text == Key.Space) {
                root.selected = !root.selected;
                root.toggled();
                return accept;
            }
            return reject;
        }
    }
    ta := TouchArea {
        width: 100%;
        height: 100%;
        clicked => {
            wc-fs.focus();
            root.selected = !root.selected;
            root.toggled();
        }
    }
}

export component TabBtn inherits Rectangle {
    in property <string> text;
    in property <bool>   active;
    callback clicked;

    accessible-role: tab;
    accessible-label: root.text;
    accessible-action-default => { root.clicked(); }

    height: 40px;
    background: Theme.tab-bar-bg;

    Rectangle {
        background: Theme.text-hi;
        opacity: !root.active && ta.has-hover ? 0.05 : 0.0;
        animate opacity { duration: 150ms; easing: ease-out; }
    }

    Text {
        text: root.text;
        color: root.active
            ? Theme.tab-active-tx
            : (ta.has-hover ? Theme.tab-active-tx : Theme.tab-inactive-tx);
        font-size: 12px;
        font-weight: root.active ? 700 : 400;
        horizontal-alignment: center;
        vertical-alignment: center;
        animate color { duration: 150ms; easing: ease-out; }
    }
    indicator := Rectangle {
        x: (parent.width - self.width) / 2;
        y: parent.height - 2px;
        width: root.active ? parent.width * 0.6 : (tab-fs.has-focus ? parent.width * 0.4 : 0px);
        height: 2px;
        border-radius: 1px;
        background: @linear-gradient(90deg, Theme.tab-line-1 0%, Theme.tab-line-2 100%);
        opacity: root.active ? 1.0 : (tab-fs.has-focus ? 0.5 : 0.0);
        animate width { duration: 240ms; easing: cubic-bezier(0.16, 1, 0.3, 1); }
        animate opacity { duration: 180ms; easing: ease-out; }
    }
    tab-fs := FocusScope {
        width: 100%;
        height: 100%;
        key-pressed(event) => {
            if (event.text == Key.Return || event.text == Key.Space) {
                root.clicked();
                return accept;
            }
            return reject;
        }
    }
    ta := TouchArea {
        width: 100%;
        height: 100%;
        clicked => { tab-fs.focus(); root.clicked(); }
    }
}

export component BadgedDBtn inherits Rectangle {
    in property <string> text;
    in property <bool>   show-badge;
    in property <string> badge-label: "적용 중";
    in property <color>  badge-color: #27ae60;
    in property <color>  base-color:  Theme.btn;
    in property <color>  hover-color: Theme.btn-h;
    in property <color>  text-color:  Theme.text-hi;
    in property <color>  grad-1: #00000000;
    in property <color>  grad-2: #00000000;
    in property <color>  grad-h-1: #00000000;
    in property <color>  grad-h-2: #00000000;
    in property <color>  border-c: Theme.btn-bd;
    in property <float>  pulse-phase: 0;
    // M79: 내부 DBtn에 위임. 비활성 시 클릭/포커스/스크린리더 차단.
    in property <bool>   enabled: true;
    callback clicked;

    accessible-role: button;
    accessible-label: (root.show-badge ? (root.text + " (현재 적용 중)") : root.text)
        + (root.enabled ? "" : " (비활성)");
    accessible-action-default => { if (root.enabled) { root.clicked(); } }

    preferred-width: 0px;
    height: 44px;

    DBtn {
        x: 0px;
        y: 4px;
        width: root.width;
        height: 36px;
        text: root.text;
        base-color: root.base-color;
        hover-color: root.hover-color;
        text-color: root.text-color;
        grad-1: root.grad-1;
        grad-2: root.grad-2;
        grad-h-1: root.grad-h-1;
        grad-h-2: root.grad-h-2;
        border-c: root.border-c;
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }
    if root.show-badge : Rectangle {
        x: (root.width - 58px) / 2;
        y: 0px;
        width: 58px;
        height: 16px;
        border-radius: 8px;
        background: root.badge-color;
        opacity: 0.88 + 0.10 * Math.sin(root.pulse-phase * 1deg);
        Text {
            text: root.badge-label;
            color: #ffffff;
            font-size: 9px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}

// 3버튼 균등 분할: width = (root.width - 2*gap) / 3, gap = 8px.
// 산술 폭으로 동일 너비 보장 (HorizontalLayout stretch는 자식 preferred-width로 깨질 수 있음).
export component OptimizeRow inherits Rectangle {
    in property <bool> high-active;
    in property <bool> normal-active;
    in property <bool> low-power-active;
    in property <float> pulse-phase: 0;
    in property <float> ripple-opacity: 0.0;
    // M79: 비활성 시 3개 BadgedDBtn 모두 click/key/스크린리더 차단 + opacity 0.42 tone-down.
    // 관리자 권한 없음/게임 미실행 상태에서 호출자가 false 설정.
    in property <bool> enabled: true;
    callback high-clicked;
    callback normal-clicked;
    callback low-power-clicked;

    property <length> col-w: (root.width - 16px) / 3;
    property <length> col-1-x: 0px;
    property <length> col-2-x: root.col-w + 8px;
    property <length> col-3-x: (root.col-w + 8px) * 2;

    height: 44px;
    // M89-2: clip: true 제거 — active glow + ripple 3겹이 카드 padding(12px) 영역으로
    // 자연스럽게 새어나가게 한다. 카드 자체는 별도 clip이라 layout 영향 없음.
    opacity: root.enabled ? 1.0 : 0.42;
    animate opacity { duration: 200ms; easing: ease-out; }

    // 활성 모드 외곽 글로우 3겹. clip: false라 카드 본문 padding(12px) 영역으로 부드럽게 확산.
    if root.high-active : Rectangle {
        x: root.col-1-x - 6px; y: -6px;
        width: root.col-w + 12px;
        height: 56px;
        border-radius: 14px;
        background: Theme.btn-suc-1;
        opacity: (Theme.dark ? 0.10 : 0.05) * Theme.motion-scale;
    }
    if root.high-active : Rectangle {
        x: root.col-1-x - 4px; y: -4px;
        width: root.col-w + 8px;
        height: 52px;
        border-radius: 12px;
        background: Theme.btn-suc-1;
        opacity: (Theme.dark ? 0.16 : 0.08) * Theme.motion-scale;
    }
    if root.high-active : Rectangle {
        x: root.col-1-x - 2px; y: -2px;
        width: root.col-w + 4px;
        height: 48px;
        border-radius: 10px;
        background: Theme.btn-suc-1;
        opacity: (Theme.dark ? 0.22 : 0.11) * Theme.motion-scale;
    }
    if root.normal-active : Rectangle {
        x: root.col-2-x - 6px; y: -6px;
        width: root.col-w + 12px;
        height: 56px;
        border-radius: 14px;
        background: Theme.btn-sec-1;
        opacity: (Theme.dark ? 0.10 : 0.05) * Theme.motion-scale;
    }
    if root.normal-active : Rectangle {
        x: root.col-2-x - 4px; y: -4px;
        width: root.col-w + 8px;
        height: 52px;
        border-radius: 12px;
        background: Theme.btn-sec-1;
        opacity: (Theme.dark ? 0.16 : 0.08) * Theme.motion-scale;
    }
    if root.normal-active : Rectangle {
        x: root.col-2-x - 2px; y: -2px;
        width: root.col-w + 4px;
        height: 48px;
        border-radius: 10px;
        background: Theme.btn-sec-1;
        opacity: (Theme.dark ? 0.22 : 0.11) * Theme.motion-scale;
    }
    if root.low-power-active : Rectangle {
        x: root.col-3-x - 6px; y: -6px;
        width: root.col-w + 12px;
        height: 56px;
        border-radius: 14px;
        background: Theme.btn-lp-1;
        opacity: (Theme.dark ? 0.10 : 0.05) * Theme.motion-scale;
    }
    if root.low-power-active : Rectangle {
        x: root.col-3-x - 4px; y: -4px;
        width: root.col-w + 8px;
        height: 52px;
        border-radius: 12px;
        background: Theme.btn-lp-1;
        opacity: (Theme.dark ? 0.16 : 0.08) * Theme.motion-scale;
    }
    if root.low-power-active : Rectangle {
        x: root.col-3-x - 2px; y: -2px;
        width: root.col-w + 4px;
        height: 48px;
        border-radius: 10px;
        background: Theme.btn-lp-1;
        opacity: (Theme.dark ? 0.22 : 0.11) * Theme.motion-scale;
    }

    BadgedDBtn {
        x: root.col-1-x;
        y: 0px;
        width: root.col-w;
        height: 44px;
        text: "고성능";
        show-badge: root.high-active;
        badge-color: Theme.badge-high;
        pulse-phase: root.pulse-phase;
        base-color: root.high-active ? Theme.btn-high : Theme.btn;
        hover-color: root.high-active ? Theme.btn-high-h : Theme.btn-h;
        text-color: root.high-active ? Theme.text-btn-high : Theme.text-lo;
        grad-1: root.high-active ? Theme.btn-suc-1 : #00000000;
        grad-2: root.high-active ? Theme.btn-suc-2 : #00000000;
        grad-h-1: root.high-active ? Theme.btn-suc-2 : #00000000;
        grad-h-2: root.high-active ? Theme.btn-suc-1 : #00000000;
        enabled: root.enabled;
        clicked => { root.high-clicked(); }
    }
    BadgedDBtn {
        x: root.col-2-x;
        y: 0px;
        width: root.col-w;
        height: 44px;
        text: "일반";
        show-badge: root.normal-active;
        badge-color: Theme.tgl-on;
        pulse-phase: root.pulse-phase;
        base-color: root.normal-active ? Theme.btn-sd-act : Theme.btn;
        hover-color: root.normal-active ? Theme.btn-sd-act-h : Theme.btn-h;
        text-color: root.normal-active ? Theme.text-btn-sd : Theme.text-lo;
        grad-1: root.normal-active ? Theme.btn-sec-1 : #00000000;
        grad-2: root.normal-active ? Theme.btn-sec-2 : #00000000;
        grad-h-1: root.normal-active ? Theme.btn-sec-2 : #00000000;
        grad-h-2: root.normal-active ? Theme.btn-sec-1 : #00000000;
        enabled: root.enabled;
        clicked => { root.normal-clicked(); }
    }
    BadgedDBtn {
        x: root.col-3-x;
        y: 0px;
        width: root.col-w;
        height: 44px;
        text: "저전력";
        show-badge: root.low-power-active;
        badge-color: Theme.badge-low-power;
        pulse-phase: root.pulse-phase;
        base-color: root.low-power-active ? Theme.btn-low-power : Theme.btn;
        hover-color: root.low-power-active ? Theme.btn-low-power-h : Theme.btn-h;
        text-color: root.low-power-active ? Theme.text-btn-low-power : Theme.text-lo;
        grad-1: root.low-power-active ? Theme.btn-lp-1 : #00000000;
        grad-2: root.low-power-active ? Theme.btn-lp-2 : #00000000;
        grad-h-1: root.low-power-active ? Theme.btn-lp-2 : #00000000;
        grad-h-2: root.low-power-active ? Theme.btn-lp-1 : #00000000;
        enabled: root.enabled;
        clicked => { root.low-power-clicked(); }
    }
    // M89-2: 모드 적용 ripple 3겹 강화 — 안쪽 채움 + 중간 확장 + 외곽 glow ring.
    // 활성 모드별 accent 색상을 사용해 시각적 의도 강조 (높은 ripple = 사용자 액션 확인).
    property <color> ripple-color:
        root.high-active ? Theme.btn-suc-1
      : root.normal-active ? Theme.btn-sec-1
      : Theme.btn-lp-1;
    property <length> ripple-col-x:
        root.high-active ? root.col-1-x
      : root.normal-active ? root.col-2-x
      : root.col-3-x;

    // 안쪽 채움 (column 영역 정확히)
    if root.ripple-opacity > 0.0 : Rectangle {
        x: root.ripple-col-x;
        y: 0;
        width: root.col-w;
        height: 44px;
        border-radius: 6px;
        background: root.ripple-color;
        opacity: root.ripple-opacity * 0.28;
    }
    // 중간 확장 — column 외곽 6px
    if root.ripple-opacity > 0.0 : Rectangle {
        x: root.ripple-col-x - 6px;
        y: -6px;
        width: root.col-w + 12px;
        height: 56px;
        border-radius: 10px;
        background: root.ripple-color;
        opacity: root.ripple-opacity * 0.14;
    }
    // 외곽 glow ring — column 외곽 12px
    if root.ripple-opacity > 0.0 : Rectangle {
        x: root.ripple-col-x - 12px;
        y: -12px;
        width: root.col-w + 24px;
        height: 68px;
        border-radius: 14px;
        background: root.ripple-color;
        opacity: root.ripple-opacity * 0.08;
    }
}
